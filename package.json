{
  "name": "@ankhorage/surface",
  "type": "module",
  "version": "0.0.1",
  "description": "Render foundation for Ankhorage and standalone React Native or Expo apps.",
  "license": "MIT",
  "main": "./dist/index.js",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "peerDependencies": {
    "@expo/vector-icons": ">=14.0.0",
    "expo-font": ">=14.0.4",
    "react": ">=18.2.0",
    "react-native": ">=0.72.0"
  },
  "peerDependenciesMeta": {
    "@expo/vector-icons": {
      "optional": true
    },
    "expo-font": {
      "optional": true
    }
  },
  "dependencies": {
    "@ankhorage/contracts": "^0.0.1",
    "culori": "^4.0.2"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && bun x tsc -p tsconfig.json",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "format": "prettier --write .",
    "test": "bun test src"
  },
  "devDependencies": {
    "@ankhorage/devtools": "^1.0.0",
    "@changesets/cli": "^2.30.0",
    "@expo/vector-icons": "^15.0.3",
    "@types/bun": "^1.3.8",
    "@types/culori": "^4.0.1",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.11"
}
