{
  "name": "@ankhorage/surface",
  "type": "module",
  "version": "0.0.1",
  "description": "Render foundation for Ankhorage and standalone React Native or Expo apps.",
  "main": "./dist/index.js",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "peerDependencies": {
    "react": ">=19.1.0",
    "react-native": ">=0.81.5"
  },
  "dependencies": {
    "@ankh/contracts": "file:../ankhorage4/packages/contracts",
    "@expo/vector-icons": "^15.0.3",
    "culori": "^4.0.2"
  },
  "files": [
    "dist"
  ],
  "exports": {
